programa {
    funcao inicio() {
        real N1, N2, N3, M
        escreva("Informe seu número favorito: ")
        leia(N1)
        escreva("Informe um número que não goste: ")
        leia(N2)
        escreva("Informe sua idade: ")
        leia(N3)
        M = (N1 + N2 + N3) / 3
        escreva("A média dos números é: ", M, "resultando no total de dias para a sua morte.")
    }
}